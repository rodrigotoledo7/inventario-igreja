# Configurações do Banco
MYSQL_ROOT_PASSWORD=change-me-root
MYSQL_DATABASE=igreja_db
MYSQL_USER=igreja_user
MYSQL_PASSWORD=change-me-user

# URL de conexão para o SQLAlchemy/PyMySQL
# Note que o host é 'db', o nome do serviço no docker-compose
DATABASE_URL=mysql+pymysql://igreja_user:change-me-user@db:3306/igreja_db
SECRET_KEY=change-me-app-secret
ACCESS_TOKEN_EXPIRE_MINUTES=480
CORS_ORIGINS=http://localhost,http://localhost:80,http://localhost:3000
INIT_ADMIN_USERNAME=admin
INIT_ADMIN_PASSWORD=admin1234
DEFAULT_LOCAL_NOME=Templo Sede

# Frontend
REACT_APP_API_URL=http://localhost:8000
